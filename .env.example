# app
NEXT_PUBLIC_APP_DOMAIN=
NEXT_PUBLIC_APP_NAME=
# Site origin for auth redirects and Stripe return URLs (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (https://supabase.com/dashboard)
# Social login: Dashboard → Authentication → Providers (Google, Discord).
# In each provider’s console, set redirect/callback to:
# https://<YOUR_PROJECT_REF>.supabase.co/auth/v1/callback
#
# Dashboard → Authentication → URL Configuration → Redirect URLs — include (no trailing slash on origin):
# - {NEXT_PUBLIC_SITE_URL}/auth/callback
# - {NEXT_PUBLIC_SITE_URL}/auth-desktop-callback.html   (desktop app OAuth handoff; static file in public/)
NEXT_PUBLIC_SUPABASE_URL=https://nfwurwjgmskbynjrjeqv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: Stripe webhooks + admin DB writes
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Dashboard → Products → Price IDs
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Legacy (optional; not used by Supabase path)
DATABASE_URL=